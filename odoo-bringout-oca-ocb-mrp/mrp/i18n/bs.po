#, []
msgid ""
"You are not allowed to create or edit a lot or serial number for the "
"components with the operation type \"Manufacturing\". To change this, go on "
"the operation type and tick the box \"Create New Lots/Serial Numbers for "
"Components\"."
msgstr ""
"Nije vam dozvoljeno da kreirate ili uređujete lot ili serijski broj za "
"komponente sa tipom operacije \"Proizvodnja\". Da biste to promijenili, "
"otvorite tip operacije i označite polje \"Kreiraj nove lotove/serijske "
"brojeve za komponente\"."

# model: code:addons/mrp/models/mrp_bom.py
#, []
msgid ""
"You can not create a kit-type bill of materials for products that have at "
"least one reordering rule."
msgstr ""
"Ne možete kreirati sastavnicu tipa kompleta za proizvode koji imaju najmanje"
" jedno pravilo ponovnog naručivanja."

# model: code:addons/mrp/models/mrp_bom.py
#, []
msgid ""
"You can not delete a Bill of Material with running manufacturing orders.\n"
"Please close or cancel it first."
msgstr ""
"Ne možete obrisati sastavnicu proizvoda koja se koristi na radnom nalogu u izvršavanju.\n"
"Molimo da zatvorite ili otkažete prvo radin nalog proizvodnje."

# model: code:addons/mrp/models/mrp_production.py
#, []
msgid ""
"You can only merge manufacturing orders of identical products with same BoM."
msgstr "Ne možete otkazati proizvodni nalog, radni nalog je još uvek u toku."

# model: code:addons/mrp/models/mrp_production.py
#, []
msgid ""
"You can only merge manufacturing orders with no additional components or by-"
"products."
msgstr "Ne možete potrošiti bez navođenja za koji lot ste to potrošili"

# model: code:addons/mrp/models/mrp_production.py
#, []
msgid "You can only merge manufacturing with the same operation type"
msgstr "Možete spajati samo proizvodnje istog tipa operacije"

# model: code:addons/mrp/models/mrp_production.py
#, []
msgid "You can only merge manufacturing with the same state."
msgstr "Možete spajati samo proizvodnje istog statusa."

# model: code:addons/mrp/models/mrp_production.py
#, []
msgid "You cannot cancel a manufacturing order that is already done."
msgstr "Ne možete otkazati proizvodni nalog koji je već završen."

# model: code:addons/mrp/models/mrp_workorder.py
#, []
msgid "You cannot change the workcenter of a work order that is done."
msgstr "Ne možete promijeniti radni centar radnog naloga koji je završen."

# model: code:addons/mrp/models/mrp_bom.py
#, []
msgid "You cannot create a new Bill of Material from here."
msgstr "Ne možete kreirati novu sastavnicu odavde."

# model: code:addons/mrp/models/mrp_routing.py
#, []
msgid "You cannot create cyclic dependency."
msgstr "Ne možete kreirati cikličnu zavisnost."

# model: code:addons/mrp/models/mrp_production.py
#, []
msgid "You cannot delete a manufacturing order that is already done."
msgstr "Ne možete obrisati proizvodni nalog koji je već završen."

# model: code:addons/mrp/models/mrp_unbuild.py
#, []
msgid "You cannot delete an unbuild order if the state is 'Done'."
msgstr ""
"Ne možete otkazati proizvodni nalog ako ste već potrošili materijal."
"             Ako želite da otkažete ovaj MO, molimo promenite potrošene "
"količine na 0."

# model: code:addons/mrp/models/mrp_production.py
#, []
msgid "You cannot have %s  as the finished product and in the Byproducts"
msgstr "Ne možete imati %s kao gotov proizvod i u nusproduktima"

# model: code:addons/mrp/models/mrp_workorder.py
#, []
msgid "You cannot link this work order to another manufacturing order."
msgstr "Ne možete povezati ovaj radni nalog sa drugim proizvodnim nalogom."

# model: code:addons/mrp/models/mrp_production.py
#, []
msgid "You cannot move a manufacturing order once it is cancelled or done."
msgstr "Ne možete pomjeriti proizvodni nalog kada je otkazan ili završen."

# model: code:addons/mrp/models/stock_picking.py
#, []
msgid ""
"You cannot set a scrap location as the destination location for a "
"manufacturing type operation."
msgstr ""
"Ne možete postaviti lokaciju otpisa kao odredišnu lokaciju za operaciju tipa"
" proizvodnje."

# model: code:addons/mrp/models/mrp_production.py
#, []
msgid "You cannot set more than 1 lot"
msgstr "Ne možete postaviti više od 1 lota"

# model: code:addons/mrp/models/mrp_production.py
#, []
msgid "You cannot set more than 1 lot per product"
msgstr "Ne možete postaviti više od 1 lota po proizvodu"

# model: code:addons/mrp/models/mrp_workorder.py
#, []
msgid "You cannot start a work order that is already done or cancelled"
msgstr "Ne možete pokrenuti radni nalog koji je već završen ili otkazan"

# model: code:addons/mrp/models/mrp_unbuild.py
#, []
msgid "You cannot unbuild a undone manufacturing order."
msgstr "Ne možete rastaviti nezavršen proizvodni nalog."

# model: code:addons/mrp/models/mrp_bom.py
#, []
msgid ""
"You cannot use the 'Apply on Variant' functionality and simultaneously "
"create a BoM for a specific variant."
msgstr ""
"Ne možete koristiti funkcionalnost 'Primijeni na varijantu' i istovremeno "
"kreirati sastavnicu za specifičnu varijantu."

